{
  "appId":    "com.todiy.app",
  "appName":  "TODIY",
  "webDir":   "www",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor":    "#050a12",
      "showSpinner":        false
    },
    "LocalNotifications": {
      "iconColor": "#4fc3f7",
      "sound":     "default"
    }
  }
}
